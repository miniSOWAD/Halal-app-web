APP_NAME=HalalFit Global
APP_ENV=development
DEBUG=false
API_PREFIX=/api

# Neon pooled URL for FastAPI. Keep ssl=require.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@YOUR-POOLER.neon.tech/neondb?ssl=require

# Neon direct URL for Alembic migrations.
MIGRATION_DATABASE_URL=postgresql+psycopg://USER:PASSWORD@YOUR-ENDPOINT.neon.tech/neondb?sslmode=require

JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

FRONTEND_URLS=["http://localhost:3000","capacitor://localhost","https://localhost"]
OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_USER_AGENT=HalalFit/1.0 (your-email@example.com)
MAX_UPLOAD_MB=8
AUTO_CREATE_TABLES=false
