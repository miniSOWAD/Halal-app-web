# Local development: copy this file to .env.
APP_NAME=HalalFit Global
APP_ENV=development
DEBUG=false
API_PREFIX=/api

# Local SQLite is only for development. In FastAPI Cloud, set DATABASE_URL
# to the Neon pooled connection string as an encrypted secret.
DATABASE_URL=sqlite+aiosqlite:///./halalfit.db

# Optional direct Neon URL used only when running Alembic yourself.
# MIGRATION_DATABASE_URL=postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require

JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Easy MVP setting for web, Android and Capacitor. Authentication still uses
# Bearer tokens. Later set false and list exact origins in FRONTEND_URLS.
CORS_ALLOW_ALL=true
FRONTEND_URLS=["http://localhost:3000","capacitor://localhost","https://localhost"]

AUTO_CREATE_TABLES=true
AUTO_SEED_DATA=true
SEED_DEMO_PRODUCTS=true

# Optional first administrator. Use only for one cloud deployment, then remove.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=replace-with-a-strong-password

OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_USER_AGENT=HalalFit/1.0 (your-email@example.com)

MAX_UPLOAD_MB=8
OCR_PROVIDER=disabled
OCR_LANGUAGE=eng
OCR_API_URL=https://api.ocr.space/parse/image
# OCR_API_KEY=replace-with-your-cloud-ocr-key

# Gmail SMTP for registration, password reset and email-change OTPs.
# Enable 2-Step Verification on the Gmail account and create an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=baisakh2015@gmail.com
SMTP_PASSWORD=replace-with-a-16-character-google-app-password
SMTP_FROM_EMAIL=baisakh2015@gmail.com
SMTP_FROM_NAME=HalalFit
CONTACT_RECEIVER_EMAIL=baisakh2015@gmail.com
OTP_EXPIRE_SECONDS=120
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
