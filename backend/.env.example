# General
APP_NAME=HalalFit Global
APP_ENV=development
DEBUG=false
API_PREFIX=/api

# Local development example. FastAPI Cloud's Neon integration will inject
# a postgresql:// DATABASE_URL secret automatically.
DATABASE_URL=sqlite+aiosqlite:///./halalfit.db

# Optional direct Neon URL used only when you run Alembic yourself.
# MIGRATION_DATABASE_URL=postgresql://USER:PASSWORD@DIRECT_HOST/neondb?sslmode=require&channel_binding=require

# Required in production. Use a long random secret and mark it as a secret.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# JSON array or comma-separated list. Add your deployed web frontend domain.
FRONTEND_URLS=["http://localhost:3000","capacitor://localhost","https://localhost"]

# Database bootstrap. Suitable for the first MVP deployment.
AUTO_CREATE_TABLES=true
AUTO_SEED_DATA=true
SEED_DEMO_PRODUCTS=false

# Optional: creates the first administrator only when both values are present.
# Set these as secrets for the first deployment, then remove them after login works.
# SEED_ADMIN_EMAIL=admin@example.com
# SEED_ADMIN_PASSWORD=replace-with-a-strong-password

# Product lookup
OPEN_FOOD_FACTS_URL=https://world.openfoodfacts.org
OPEN_FOOD_FACTS_USER_AGENT=HalalFit/1.0 (your-email@example.com)

# Uploads and OCR
MAX_UPLOAD_MB=8
OCR_PROVIDER=disabled
OCR_LANGUAGE=eng
OCR_API_URL=https://api.ocr.space/parse/image
# OCR_API_KEY=replace-with-your-cloud-ocr-key
